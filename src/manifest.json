{
  "author": "Timofei Marenko",
  "action": {
    "default_icon": {
      "16": "images/icon16.png",
      "24": "images/icon24.png",
      "32": "images/icon32.png"
    },
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+U", "mac": "Command+Shift+U" },
      "description": "Open Twitch Anti-Ban menu"
    }
  },
  "content_scripts": [
    {
      "css": ["css/chat.css", "css/video-player.css"],
      "js": [
        "scripts/libs/hls.min.js",
        "scripts/libs/reconnecting-websocket.min.js",
        "scripts/proxy-chat.js",
        "scripts/proxy-stream.js",
        "scripts/utils.js",
        "scripts/content.js"
      ],
      "matches": ["*://*.twitch.tv/*"],
      "all_frames": true,
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "host_permissions": [
    "*://*.amazonaws.com/*",
    "*://*.betterttv.net/*",
    "*://*.7tv.io/*",
    "*://*.twitch.tv/*",
    "*://*.ttvnw.net/*",
    "https://discord.com/api/webhooks/*"
  ],
  "permissions": ["storage", "notifications"],
  "default_locale": "en",
  "name": "__MSG_extName__",
  "description": "__MSG_extDescription__",
  "icons": {
    "128": "images/icon128.png",
    "16": "images/icon16.png",
    "48": "images/icon48.png"
  },
  "manifest_version": 3,
  "version": "4.5"
}
